      <Chart Name="BubbleChart">
        <Legend>
          <Visible>true</Visible>
          <Style>
            <BorderStyle>
              <Default>Solid</Default>
            </BorderStyle>
            <FontFamily>Tahoma</FontFamily>
            <FontSize>9pt</FontSize>
            <BackgroundColor>WhiteSmoke</BackgroundColor>
          </Style>
          <Position>TopRight</Position>
          <Layout>Table</Layout>
        </Legend>
        <Subtype>Plain</Subtype>
        <Title>
          <Style>
            <FontFamily>Tahoma</FontFamily>
            <FontWeight>700</FontWeight>
            <FontSize>14pt</FontSize>
          </Style>
        </Title>
        <Height>4.5in</Height>
        <CategoryAxis>
          <Axis>
            <Title>
              <Caption>Benefit (€M)</Caption>
              <Style>
                <FontFamily>Tahoma</FontFamily>
                <FontWeight>700</FontWeight>
              </Style>
            </Title>
            <Style>
              <FontFamily>Tahoma</FontFamily>
              <FontSize>9pt</FontSize>
            </Style>
            <MajorGridLines>
              <Style>
                <BorderStyle>
                  <Default>Solid</Default>
                </BorderStyle>
              </Style>
            </MajorGridLines>
            <MinorGridLines>
              <Style>
                <BorderStyle>
                  <Default>Solid</Default>
                </BorderStyle>
              </Style>
            </MinorGridLines>
            <MajorTickMarks>Outside</MajorTickMarks>
            <Min>0</Min>
            <Margin>true</Margin>
            <Visible>true</Visible>
            <Scalar>true</Scalar>
          </Axis>
        </CategoryAxis>
        <PointWidth>0</PointWidth>
        <Left>0.125in</Left>
        <ThreeDProperties>
          <Enabled>true</Enabled>
          <Shading>Real</Shading>
        </ThreeDProperties>
        <DataSetName>Reports_spReport_BenefitVsSpend_ROIBubble</DataSetName>
        <Filters>
          <Filter>
            <Operator>GreaterThan</Operator>
            <FilterValues>
              <FilterValue>=0</FilterValue>
            </FilterValues>
            <FilterExpression>=Fields!InitiativeID.Value</FilterExpression>
          </Filter>
        </Filters>
        <SeriesGroupings>
          <SeriesGrouping>
            <DynamicSeries>
              <Grouping Name="ImpactCategory_Group">
                <DataElementOutput>NoOutput</DataElementOutput>
                <GroupExpressions>
                  <GroupExpression>=Fields!ImpactCategoryID.Value</GroupExpression>
                </GroupExpressions>
              </Grouping>
              <Sorting>
                <SortBy>
                  <SortExpression>=IIf(Fields!ImpactCategoryID.Value=1, 1, 
 IIf(Fields!ImpactCategoryID.Value=2, 2,
 IIf(Fields!ImpactCategoryID.Value=3, 4,
 IIf(Fields!ImpactCategoryID.Value=4, 3, 3))))</SortExpression>
                  <Direction>Ascending</Direction>
                </SortBy>
              </Sorting>
              <Label>=Fields!ImpactCategory.Value</Label>
            </DynamicSeries>
          </SeriesGrouping>
        </SeriesGroupings>
        <Top>0.5in</Top>
        <PlotArea>
          <Style>
            <BorderStyle>
              <Default>Solid</Default>
            </BorderStyle>
          </Style>
        </PlotArea>
        <ValueAxis>
          <Axis>
            <Title>
              <Caption>ROI</Caption>
              <Style>
                <FontFamily>Tahoma</FontFamily>
                <FontWeight>700</FontWeight>
              </Style>
            </Title>
            <Style>
              <FontFamily>Tahoma</FontFamily>
              <FontSize>9pt</FontSize>
            </Style>
            <MajorGridLines>
              <ShowGridLines>true</ShowGridLines>
              <Style>
                <BorderStyle>
                  <Default>Solid</Default>
                </BorderStyle>
              </Style>
            </MajorGridLines>
            <MinorGridLines>
              <Style>
                <BorderStyle>
                  <Default>Solid</Default>
                </BorderStyle>
              </Style>
            </MinorGridLines>
            <MajorTickMarks>Outside</MajorTickMarks>
            <Min>0</Min>
            <Margin>true</Margin>
            <Visible>true</Visible>
            <Scalar>true</Scalar>
          </Axis>
        </ValueAxis>
        <ZIndex>2</ZIndex>
        <Type>Bubble</Type>
        <Width>10.625in</Width>
        <Palette>Default</Palette>
        <ChartData>
          <ChartSeries>
            <DataPoints>
              <DataPoint>
                <DataValues>
                  <DataValue>
                    <Value>=Fields!TotalBenefit.Value</Value>
                  </DataValue>
                  <DataValue>
                    <Value>= IIf(Fields!TotalSpend.Value &lt;&gt; 0, Fields!TotalBenefit.Value / IIf(Fields!TotalSpend.Value &lt;&gt; 0, Fields!TotalSpend.Value, 1), 0)</Value>
                  </DataValue>
                  <DataValue>
                    <Value>=Fields!TotalSpend.Value</Value>
                  </DataValue>
                </DataValues>
                <DataLabel>
                  <Style>
                    <FontFamily>Tahoma</FontFamily>
                    <FontSize>8pt</FontSize>
                  </Style>
                </DataLabel>
                <Action>
                  <Hyperlink>=IIf(CStr(Fields!InitiativeID.Value)&lt;&gt;"", "javascript:void(window.open('BubbleInfo.aspx?InitiativeID="&amp;CStr(Fields!InitiativeID.Value)&amp;"','bubble_dialog','height=150,width=875,status=no,toolbar=no,menubar=no,location=no'))", "")</Hyperlink>
                </Action>
                <Style />
                <Marker>
                  <Size>6pt</Size>
                </Marker>
                <DataElementOutput>NoOutput</DataElementOutput>
              </DataPoint>
            </DataPoints>
          </ChartSeries>
        </ChartData>
        <Style>
          <BorderStyle>
            <Default>Solid</Default>
          </BorderStyle>
          <BorderWidth>
            <Default>0.25pt</Default>
          </BorderWidth>
          <BorderColor>
