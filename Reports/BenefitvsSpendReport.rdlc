          <BackgroundColor>LightSteelBlue</BackgroundColor>
          <BackgroundGradientEndColor>WhiteSmoke</BackgroundGradientEndColor>
          <BackgroundGradientType>TopBottom</BackgroundGradientType>
        </Style>
