  <Code>Private colorList As String() = { _
	"#6666FF","#6699FF","#66CCFF","#66FFFF","#9966FF","#9999FF","#99CCFF","#99FFFF", _
	"#CC66FF","#CC99FF","#CCCCFF","#CCFFFF","#FF66FF","#FF99FF","#FFCCFF","#666666", _
	"#669966","#66CC66","#66FF66","#996666","#999966","#99CC66","#99FF66","#CC6666", _
	"#CC9966","#CCCC66","#CCFF66","#FF6666","#FF9966","#FFCC66","#FFFF66","#666699", _
	"#669999","#66CC99","#66FF99","#996699","#999999","#99CC99","#99FF99","#CC6699", _
	"#CC9999","#CCCC99","#CCFF99","#FF6699","#FF9999","#FFCC99","#FFFF99","#6666CC", _
	"#6699CC","#66CCCC","#66FFCC","#9966CC","#9999CC","#99CCCC","#99FFCC","#CC66CC", _
	"#CC99CC","#CCCCCC","#CCFFCC","#FF66CC","#FF99CC","#FFCCCC","#FFFFCC","#FFFFFF"  _
	}

Private count As Integer = 0

Private mapping As New System.Collections.Hashtable()

Public Function GetColor(ByVal groupingValue As String) As String
	If mapping.ContainsKey(groupingValue) Then
		Return mapping(groupingValue)
	End If
	Dim c As String = colorList(count Mod colorList.Length)
	count = count + 1
	mapping.Add(groupingValue, c)
	Return c
End Function
</Code>
