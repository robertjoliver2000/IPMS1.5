        protected void rptPayBack_ItemDataBound(object sender, RepeaterItemEventArgs e)
        {
            if (e.Item.ItemType == ListItemType.Footer)
            {
                HtmlTableCell tdTotalCell, tdNetCashFlow, tdNetCashFlowCumulated;
                object objTotalBenefits, objTotalExpenses;
                decimal dTotalBenefits, dTotalExpenses, dCumulatedCashFlow = 0.0m;

                HtmlTableRow trNetCashFlow = (HtmlTableRow)e.Item.FindControl("trNetCashFlow");
                HtmlTableRow trNetCashFlowCumulated = (HtmlTableRow)e.Item.FindControl("trNetCashFlowCumulated");

                foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                {
                    //if ((bool)drPeriod["HasQuarters"])
                    if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                    {
                        for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                        {
                            tdNetCashFlow = new HtmlTableCell();
                            tdNetCashFlowCumulated = new HtmlTableCell();

                            objTotalBenefits = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                                "CategoryID=1 AND " +
                                                                "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                                "QuarterNo=" + quarterIndex.ToString());

                            objTotalExpenses = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                                "(CategoryID=2 OR CategoryID=3 OR CategoryID=4 OR CategoryID=5 OR " +
                                                                        "CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND " + //rev 1.2.1 added Category 15 CA
                                                                "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                                "QuarterNo=" + quarterIndex.ToString());

                            dTotalBenefits = (objTotalBenefits == DBNull.Value) ? 0.0m : (Decimal)objTotalBenefits;
                            dTotalExpenses = (objTotalExpenses == DBNull.Value) ? 0.0m : (Decimal)objTotalExpenses;

                            dCumulatedCashFlow += (dTotalBenefits - dTotalExpenses);

                            tdNetCashFlow.InnerText = (dTotalBenefits - dTotalExpenses).ToString("N2");
                            tdNetCashFlow.Attributes.Add("Class", "totalcell");
                            tdNetCashFlow.Attributes.Add("Width", DefaultCellWidth);
                            tdNetCashFlow.Attributes.Add("Align", "center");
                            tdNetCashFlow.Attributes.Add("style", "");

                            tdNetCashFlowCumulated.InnerText = dCumulatedCashFlow.ToString("N2");
                            tdNetCashFlowCumulated.Attributes.Add("Class", "totalcell");
                            tdNetCashFlowCumulated.Attributes.Add("Width", DefaultCellWidth);
                            tdNetCashFlowCumulated.Attributes.Add("Align", "center");
                            tdNetCashFlowCumulated.Attributes.Add("style", "");

                            trNetCashFlow.Cells.Add(tdNetCashFlow);
                            trNetCashFlowCumulated.Cells.Add(tdNetCashFlowCumulated);
                        }
                    }
                    else
                    {
                        tdNetCashFlow = new HtmlTableCell();
                        tdNetCashFlowCumulated = new HtmlTableCell();

                        objTotalBenefits = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                            "CategoryID=1 AND " +
                                                            "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                            "QuarterNo IS NULL");

                        objTotalExpenses = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                            "(CategoryID=2 OR CategoryID=3 OR CategoryID=4 OR CategoryID=5 OR " +
                                                                    "CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND " + //rev 1.2.1 added Category 15 CA
                                                            "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                            "QuarterNo IS NULL");

                        dTotalBenefits = (objTotalBenefits == DBNull.Value) ? 0.0m : (Decimal)objTotalBenefits;
                        dTotalExpenses = (objTotalExpenses == DBNull.Value) ? 0.0m : (Decimal)objTotalExpenses;

                        dCumulatedCashFlow += (dTotalBenefits - dTotalExpenses);

                        tdNetCashFlow.InnerText = (dTotalBenefits - dTotalExpenses).ToString("N2");
                        tdNetCashFlow.Attributes.Add("Class", "totalcell");
                        tdNetCashFlow.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdNetCashFlow.Attributes.Add("Align", "center");
                        tdNetCashFlow.Attributes.Add("style", "");

                        tdNetCashFlowCumulated.InnerText = dCumulatedCashFlow.ToString("N2");
                        tdNetCashFlowCumulated.Attributes.Add("Class", "totalcell");
                        tdNetCashFlowCumulated.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdNetCashFlowCumulated.Attributes.Add("Align", "center");
                        tdNetCashFlowCumulated.Attributes.Add("style", "");

                        trNetCashFlow.Cells.Add(tdNetCashFlow);
                        trNetCashFlowCumulated.Cells.Add(tdNetCashFlowCumulated);
                    }
                }

                tdTotalCell = new HtmlTableCell();

                objTotalBenefits = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)", "CategoryID=1");
                objTotalExpenses = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                    "(CategoryID=2 OR CategoryID=3 OR CategoryID=4 OR CategoryID=5 OR " +
                                                    " CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15)"); //rev 1.2.1 added Category 15 CA

                dTotalBenefits = (objTotalBenefits == DBNull.Value) ? 0.0m : (Decimal)objTotalBenefits;
                dTotalExpenses = (objTotalExpenses == DBNull.Value) ? 0.0m : (Decimal)objTotalExpenses;

                tdTotalCell.InnerText = (dTotalBenefits - dTotalExpenses).ToString("N2");

                tdTotalCell.Attributes.Add("Class", "totalcell");
                tdTotalCell.Attributes.Add("Width", DefaultCellWidth);
                tdTotalCell.Attributes.Add("Align", "center");
                tdTotalCell.Attributes.Add("style", "");

                trNetCashFlow.Cells.Add(tdTotalCell);

                tdTotalCell = new HtmlTableCell();
                tdTotalCell.Attributes.Add("Class", "empty");
                trNetCashFlowCumulated.Cells.Add(tdTotalCell);

                tdTotalCell = new HtmlTableCell();
                tdTotalCell.Attributes.Add("Class", "emptynopadding");
                trNetCashFlow.Cells.Add(tdTotalCell);

                tdTotalCell = new HtmlTableCell();
                tdTotalCell.Attributes.Add("Class", "emptynopadding");
                trNetCashFlowCumulated.Cells.Add(tdTotalCell);
            }

        }


        protected void repeaters_DoDefaultHeaderBind(object sender, RepeaterItemEventArgs e)
        {
            if (e.Item.ItemType == ListItemType.Header)
            {
                HtmlTableRow trHeaderRow = (HtmlTableRow)e.Item.FindControl("trHeader");
                HtmlTableCell tdTitleCell;

                HtmlTableCell tdSpanTitle = (HtmlTableCell)e.Item.FindControl("tdSpanTitle");

                if (tdSpanTitle != null)
                {
                    tdSpanTitle.Attributes["colspan"] = ((int)m_dsPeriod.Tables["Period"].Compute("COUNT(PeriodID)", "") +
                                                        (int)m_dsPeriod.Tables["Period"].Compute("COUNT(PeriodID)*3", "HasQuarters=1")
                                                            + 1).ToString();
                }

                foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                {
                    //if ((bool)drPeriod["HasQuarters"])
                    if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                    {
                        for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                        {
                            tdTitleCell = new HtmlTableCell();
                            tdTitleCell.InnerText = "Q" + quarterIndex.ToString() + " " + drPeriod["Name"].ToString();
                            tdTitleCell.Attributes.Add("Class", "headcell");
                            tdTitleCell.Attributes.Add("Width", DefaultCellWidth);
                            tdTitleCell.Attributes.Add("Align", "center");
                            trHeaderRow.Cells.Add(tdTitleCell);
                        }
                    }
                    else
                    {
                        tdTitleCell = new HtmlTableCell();
                        tdTitleCell.InnerText = drPeriod["Name"].ToString();
                        tdTitleCell.Attributes.Add("Class", "headcell");
                        tdTitleCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdTitleCell.Attributes.Add("Align", "center");
                        trHeaderRow.Cells.Add(tdTitleCell);
                    }
                }

                tdTitleCell = new HtmlTableCell();
                tdTitleCell.InnerText = "TOTAL";
                tdTitleCell.Attributes.Add("Class", "headcell");
                tdTitleCell.Attributes.Add("Width", DefaultCellWidth);
                tdTitleCell.Attributes.Add("Align", "center");
                trHeaderRow.Cells.Add(tdTitleCell);

                tdTitleCell = new HtmlTableCell();
                tdTitleCell.Attributes.Add("Class", "emptynopadding");
                trHeaderRow.Cells.Add(tdTitleCell);
            }
        }


        protected void repeaters_DoDefaultItemBind(object sender, RepeaterItemEventArgs e)
        {
            if (e.Item.ItemType == ListItemType.Item || e.Item.ItemType == ListItemType.AlternatingItem)
            {
                if (DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID") != DBNull.Value)
                {
                    ImageButton imgDelete = (ImageButton)e.Item.FindControl("imgDelete");
                    if (imgDelete != null)
                    {
                        imgDelete.Attributes.Add("onclick", "javascript: if (confirm('Are you sure you wish to delete this record?')) AllowOneTimeSubmit(); else return false;");
                    }

                    int intInitiativeFinancialID = (int)DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID");

                    // Rev 1.7.2 GMcF
                    TextBox txtLegacyRTBExistingCheck = (TextBox)e.Item.FindControl("txtLegacyRTBExistingCheck");
                    if (txtLegacyRTBExistingCheck != null)
                    {
                        txtLegacyRTBExistingCheck.Text = Convert.ToString(DataBinder.Eval(e.Item.DataItem, "CategoryID")) + "|" + (string)DataBinder.Eval(e.Item.DataItem, "IGApprovalStatus");
                        string strCheck;
                        switch( Convert.ToString(DataBinder.Eval(e.Item.DataItem, "CategoryID")) + "|" + (string)DataBinder.Eval(e.Item.DataItem, "IGApprovalStatus") )
                        {
                            case "9|IG Draft":
                            case "9|In Review":
                            case "9|Budget Request":
                                strCheck = "";
                                break;
                            default:
                                strCheck = "OK";
                                break;
                        }
                        txtLegacyRTBExistingCheck.Text = strCheck;
                    }
                    // End of Rev 1.7.2

                    HtmlTableCell tdValueCell;
                    object objValue;
                    HtmlTableRow trItemRow = (HtmlTableRow)e.Item.FindControl("trItem");

                    foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                    {
                        //if ((bool)drPeriod["HasQuarters"])
                        if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                        {
                            for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                            {
                                tdValueCell = new HtmlTableCell();

                                DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                              "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                              "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                              "QuarterNo=" + quarterIndex.ToString());
                                if (drValues.Length > 0) objValue = drValues[0]["Amount"]; else objValue = DBNull.Value;

                                tdValueCell.InnerText = (objValue == DBNull.Value) ? "0.00" : ((Decimal)objValue).ToString("N2");

                                tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                                tdValueCell.Attributes.Add("Width", DefaultCellWidth);
                                tdValueCell.Attributes.Add("Align", "center");
                                trItemRow.Cells.Add(tdValueCell);
                            }
                        }
                        else
                        {
                            tdValueCell = new HtmlTableCell();

                            DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                             "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                             "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                             "QuarterNo IS NULL");
                            if (drValues.Length > 0) objValue = drValues[0]["Amount"]; else objValue = DBNull.Value;

                            tdValueCell.InnerText = (objValue == DBNull.Value) ? "0.00" : ((Decimal)objValue).ToString("N2");

                            tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                            tdValueCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                            tdValueCell.Attributes.Add("Align", "center");
                            trItemRow.Cells.Add(tdValueCell);
                        }
                    }

                    tdValueCell = new HtmlTableCell();

                    objValue = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                             "ReferenceID = " + intInitiativeFinancialID.ToString());

                    tdValueCell.InnerText = (objValue == DBNull.Value) ? "0.00" : ((Decimal)objValue).ToString("N2");
                    tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                    tdValueCell.Attributes.Add("Width", DefaultCellWidth);
                    tdValueCell.Attributes.Add("Align", "center");

                    trItemRow.Cells.Add(tdValueCell);

                    tdValueCell = new HtmlTableCell();
                    tdValueCell.Attributes.Add("Class", "emptynopadding");
                    trItemRow.Cells.Add(tdValueCell);
                }
                else
                {
                    ImageButton imgDelete = (ImageButton)e.Item.FindControl("imgDelete");
                    if (imgDelete != null) imgDelete.Visible = false;

                    HtmlAnchor lnkAddFinancial = (HtmlAnchor)e.Item.FindControl("lnkAddFinancial");
                    lnkAddFinancial.Attributes["onclick"] = "";
                    lnkAddFinancial.HRef = "";

                    HtmlTableCell tdValueCell;
                    object objValue;
                    HtmlTableRow trItemRow = (HtmlTableRow)e.Item.FindControl("trItem");

                    foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                    {
                        //if ((bool)drPeriod["HasQuarters"])
                        if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                        {
                            for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                            {
                                tdValueCell = new HtmlTableCell();
                                tdValueCell.InnerHtml = "&nbsp;";
                                tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                                tdValueCell.Attributes.Add("Width", DefaultCellWidth);
                                tdValueCell.Attributes.Add("Align", "center");
                                trItemRow.Cells.Add(tdValueCell);
                            }
                        }
                        else
                        {
                            tdValueCell = new HtmlTableCell();
                            tdValueCell.InnerHtml = "&nbsp;";
                            tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                            tdValueCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                            tdValueCell.Attributes.Add("Align", "center");
                            trItemRow.Cells.Add(tdValueCell);
                        }
                    }

                    tdValueCell = new HtmlTableCell();
                    tdValueCell.InnerHtml = "&nbsp;";
                    tdValueCell.Attributes.Add("Class", e.Item.ItemType == ListItemType.AlternatingItem ? "alternateincell" : "incell");
                    tdValueCell.Attributes.Add("Width", DefaultCellWidth);
                    tdValueCell.Attributes.Add("Align", "center");
                    trItemRow.Cells.Add(tdValueCell);

                    tdValueCell = new HtmlTableCell();
                    tdValueCell.Attributes.Add("Class", "emptynopadding");
                    trItemRow.Cells.Add(tdValueCell);
                }
            }
        }


        private void repeaters_DoDefaultFooterBind(object sender, RepeaterItemEventArgs e, string categoryFilter,
                                                    string rowID, string style, string cssClass)
        {
            if (e.Item.ItemType == ListItemType.Footer)
            {
                HtmlTableCell tdTotalCell;
                object objTotal;
                HtmlTableRow trItemRow = (HtmlTableRow)e.Item.FindControl(rowID);

                HtmlTableCell tdSpan = (HtmlTableCell)e.Item.FindControl("tdSpan");

                if (tdSpan != null)
                {
                    tdSpan.Attributes["colspan"] = ((int)m_dsPeriod.Tables["Period"].Compute("COUNT(PeriodID)", "") +
                                                    (int)m_dsPeriod.Tables["Period"].Compute("COUNT(PeriodID)*3", "HasQuarters=1")
                                                         + 1).ToString();
                }

                foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                {
                    //if ((bool)drPeriod["HasQuarters"])
                    if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                    {
                        for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                        {
                            tdTotalCell = new HtmlTableCell();

                            objTotal = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                                categoryFilter + " AND " +
                                                                "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                                "QuarterNo=" + quarterIndex.ToString());

                            tdTotalCell.InnerText = (objTotal == DBNull.Value) ? "0.00" : ((Decimal)objTotal).ToString("N2");

                            tdTotalCell.Attributes.Add("Class", cssClass);
                            tdTotalCell.Attributes.Add("Width", DefaultCellWidth);
                            tdTotalCell.Attributes.Add("Align", "center");
                            tdTotalCell.Attributes.Add("style", style);
                            trItemRow.Cells.Add(tdTotalCell);
                        }
                    }
                    else
                    {
                        tdTotalCell = new HtmlTableCell();

                        objTotal = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                            categoryFilter + " AND " +
                                                            "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                                            "QuarterNo IS NULL");

                        tdTotalCell.InnerText = (objTotal == DBNull.Value) ? "0.00" : ((Decimal)objTotal).ToString("N2");

                        tdTotalCell.Attributes.Add("Class", cssClass);
                        tdTotalCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdTotalCell.Attributes.Add("Align", "center");
                        tdTotalCell.Attributes.Add("style", style);
                        trItemRow.Cells.Add(tdTotalCell);
                    }
                }

                tdTotalCell = new HtmlTableCell();

                objTotal = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                    categoryFilter);

                tdTotalCell.InnerText = (objTotal == DBNull.Value) ? "0.00" : ((Decimal)objTotal).ToString("N2");
                tdTotalCell.Attributes.Add("Class", cssClass);
                tdTotalCell.Attributes.Add("Width", DefaultCellWidth);
                tdTotalCell.Attributes.Add("Align", "center");
                tdTotalCell.Attributes.Add("style", style);

                trItemRow.Cells.Add(tdTotalCell);

                tdTotalCell = new HtmlTableCell();
                tdTotalCell.Attributes.Add("Class", "emptynopadding");
                trItemRow.Cells.Add(tdTotalCell);
            }
        }


        private void repeaters_DoDefaultDepreciationBind(object sender, RepeaterItemEventArgs e, int categoryID,
                                                        string rowID, string style, string popupText)
        {
            if (e.Item.ItemType == ListItemType.Footer)
            {
                DataRow[] drRecords = m_dsFinancialRecords.Tables["FinancialRecords"].Select(
                                    "CategoryID=" + categoryID.ToString());

                ImageButton imgDelete = (ImageButton)e.Item.FindControl("imgDelete");
                if (imgDelete != null)
                {
                    if (drRecords.Length > 0)
                    {
                        imgDelete.CommandArgument = drRecords[0]["InitiativeFinancialID"].ToString();

                        if (categoryID == 9)
                            imgDelete.Attributes.Add("onclick", "javascript: if (confirm('Are you sure you wish to clear RTB Existing values?')) AllowOneTimeSubmit(); else return false;");
                        else
                            imgDelete.Attributes.Add("onclick", "javascript: if (confirm('Are you sure you wish to clear depreciation values?')) AllowOneTimeSubmit(); else return false;");
                    }
                    else
                    {
                        imgDelete.Visible = false;
                    }
                }

                HtmlTableCell tdDepreciationType = (HtmlTableCell)e.Item.FindControl("tdDepreciationType");
                if (tdDepreciationType != null && drRecords.Length > 0)
                {
                    tdDepreciationType.InnerText = drRecords[0]["Type"].ToString();
                }

                HtmlTableCell tdDescription = (HtmlTableCell)e.Item.FindControl("tdDescription");

                tdDescription.Attributes.Add("onMouseOver", "toolTip('" + popupText + "')");
                tdDescription.Attributes.Add("onMouseOut", "toolTip()");

                int intInitiativeFinancialID = 0;

                if (drRecords.Length > 0)
                {
                    intInitiativeFinancialID = (int)drRecords[0]["InitiativeFinancialID"];

                    HtmlAnchor aEditRecord = new HtmlAnchor();

                    aEditRecord.InnerText = drRecords[0]["Description"].ToString();
                    aEditRecord.HRef = "#";
                    aEditRecord.Attributes.Add("onClick", "javascript: popupWindowEditFinancial(" +
                                    drRecords[0]["InitiativeID"].ToString() + ", " +
                                    categoryID.ToString() + ", " +
                                    drRecords[0]["InitiativeFinancialID"].ToString() + "); " +
                                    "return false; ");

                    tdDescription.Controls.Add(aEditRecord);

                    HtmlTableCell tdStartDate = (HtmlTableCell)e.Item.FindControl("tdStartDate");

                    if (tdStartDate != null && categoryID != 9)
                    {
                        tdStartDate.InnerText = (drRecords[0]["StartDate"] != DBNull.Value) ? ((DateTime)drRecords[0]["StartDate"]).ToShortDateString() : String.Empty;
                    }
                }

                HtmlTableCell tdDepreciationCell;
                object objDepreciation;
                HtmlTableRow trItemRow = (HtmlTableRow)e.Item.FindControl(rowID);

                foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                {
                    //if ((bool)drPeriod["HasQuarters"])
                    if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                    {
                        for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                        {
                            DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                              "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                              "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                              "QuarterNo=" + quarterIndex.ToString());

                            if (drValues.Length > 0) objDepreciation = drValues[0]["Amount"]; else objDepreciation = DBNull.Value;

                            tdDepreciationCell = new HtmlTableCell();

                            tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";

                            tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                            tdDepreciationCell.Attributes.Add("Width", DefaultCellWidth);
                            tdDepreciationCell.Attributes.Add("Align", "center");
                            tdDepreciationCell.Attributes.Add("style", style);
                            trItemRow.Cells.Add(tdDepreciationCell);
                        }
                    }
                    else
                    {
                        DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                          "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                          "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                          "QuarterNo IS NULL");

                        if (drValues.Length > 0)
                            objDepreciation = drValues[0]["Amount"];
                        else objDepreciation = DBNull.Value;

                        tdDepreciationCell = new HtmlTableCell();

                        tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";

                        tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                        tdDepreciationCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdDepreciationCell.Attributes.Add("Align", "center");
                        tdDepreciationCell.Attributes.Add("style", style);
                        trItemRow.Cells.Add(tdDepreciationCell);
                    }
                }

                tdDepreciationCell = new HtmlTableCell();

                objDepreciation = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                "ReferenceID = " + intInitiativeFinancialID.ToString());


                tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";

                tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                tdDepreciationCell.Attributes.Add("Width", DefaultCellWidth);
                tdDepreciationCell.Attributes.Add("Align", "center");
                tdDepreciationCell.Attributes.Add("style", style);

                trItemRow.Cells.Add(tdDepreciationCell);

                tdDepreciationCell = new HtmlTableCell();
                tdDepreciationCell.Attributes.Add("Class", "emptynopadding");
                trItemRow.Cells.Add(tdDepreciationCell);
            }
        }


        private void repeaters_DoDefaultDepreciationBind(object sender, RepeaterItemEventArgs e, int categoryID, string rowID, string style)
        {
            if (e.Item.ItemType == ListItemType.Item || e.Item.ItemType == ListItemType.AlternatingItem)
            {
                int intInitiativeID = 0;
                intInitiativeID = (DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID") != DBNull.Value) ? ((int)DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID")) : -1;

                //if (DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID") != DBNull.Value)
                //{
                ImageButton imgDelete = (ImageButton)e.Item.FindControl("imgDelete");
                if (imgDelete != null)
                {
                    imgDelete.CommandArgument = DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID").ToString();

                    if (intInitiativeID == -1)
                        imgDelete.Visible = false;
                    else
                    {
                        if (categoryID == 9)
                            imgDelete.Attributes.Add("onclick", "javascript: if (confirm('Are you sure you wish to clear RTB Existing values?')) AllowOneTimeSubmit(); else return false;");
                        else
                            imgDelete.Attributes.Add("onclick", "javascript: if (confirm('Are you sure you wish to delete this depreciation?')) AllowOneTimeSubmit(); else return false;");
                    }
                }

                HtmlTableCell tdDepreciationType = (HtmlTableCell)e.Item.FindControl("tdDepreciationType");
                if (tdDepreciationType != null)
                {
                    tdDepreciationType.InnerText = DataBinder.Eval(e.Item.DataItem, "Type").ToString();
                }

                HtmlTableCell tdDesription = (HtmlTableCell)e.Item.FindControl("tdDescription");
                if (tdDesription != null)
                {
                    Label aEditRecord = new Label();

                    aEditRecord.Text = DataBinder.Eval(e.Item.DataItem, "Description").ToString();
                    aEditRecord.Attributes.Add("onmouseover", "toolTip('To edit <b>Depreciation</b> please select the appropriate <b>CAPEX</b> item to edit');");
                    aEditRecord.Attributes.Add("onmouseout", "toolTip();");

                    tdDesription.Controls.Add(aEditRecord);
                }

                HtmlTableCell tdStartDate = (HtmlTableCell)e.Item.FindControl("tdStartDate");
                if (tdStartDate != null && categoryID != 9)
                {
                    tdStartDate.InnerText = (DataBinder.Eval(e.Item.DataItem, "StartDate") != DBNull.Value) ? ((DateTime)DataBinder.Eval(e.Item.DataItem, "StartDate")).ToShortDateString() : String.Empty;
                }

                HtmlTableCell tdDepreciationCell;
                object objDepreciation;
                HtmlTableRow trItemRow = (HtmlTableRow)e.Item.FindControl(rowID);

                int intInitiativeFinancialID = 0;
                intInitiativeFinancialID = (DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID") != DBNull.Value) ? (int)DataBinder.Eval(e.Item.DataItem, "InitiativeFinancialID") : -1;

                foreach (DataRow drPeriod in m_dsPeriod.Tables["Period"].Rows)
                {
                    //if ((bool)drPeriod["HasQuarters"])
                    if (Convert.ToInt16(drPeriod["HasQuarters"]) == 1)
                    {
                        for (int quarterIndex = 1; quarterIndex <= 4; quarterIndex++)
                        {
                            DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                              "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                              "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                              "QuarterNo=" + quarterIndex.ToString());

                            if (drValues.Length > 0) objDepreciation = drValues[0]["Amount"]; else objDepreciation = DBNull.Value;

                            tdDepreciationCell = new HtmlTableCell();
                            if (intInitiativeID > 0)
                                tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";
                            else
                                tdDepreciationCell.InnerText = "";

                            if (e.Item.ItemType == ListItemType.Item)
                                tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                            else
                                tdDepreciationCell.Attributes.Add("Class", "altdepreciationcell");

                            tdDepreciationCell.Attributes.Add("Width", DefaultCellWidth);
                            tdDepreciationCell.Attributes.Add("Align", "center");
                            tdDepreciationCell.Attributes.Add("style", style);
                            trItemRow.Cells.Add(tdDepreciationCell);
                        }
                    }
                    else
                    {
                        DataRow[] drValues = m_dsInitiativeValues.Tables["InitiativeValue"].Select(
                                          "ReferenceID = " + intInitiativeFinancialID.ToString() + " AND " +
                                          "PeriodID=" + drPeriod["PeriodID"].ToString() + " AND " +
                                          "QuarterNo IS NULL");

                        if (drValues.Length > 0)
                            objDepreciation = drValues[0]["Amount"];
                        else objDepreciation = DBNull.Value;

                        tdDepreciationCell = new HtmlTableCell();

                        if (intInitiativeID > 0)
                            tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";
                        else
                            tdDepreciationCell.InnerText = "";

                        if (e.Item.ItemType == ListItemType.Item)
                            tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                        else
                            tdDepreciationCell.Attributes.Add("Class", "altdepreciationcell");

                        tdDepreciationCell.Attributes.Add("Width", drPeriod["Name"].ToString().StartsWith("PRE") ? Pre2006CellWidth : DefaultCellWidth);
                        tdDepreciationCell.Attributes.Add("Align", "center");
                        tdDepreciationCell.Attributes.Add("style", style);
                        trItemRow.Cells.Add(tdDepreciationCell);
                    }
                }

                tdDepreciationCell = new HtmlTableCell();

                objDepreciation = m_dsInitiativeValues.Tables["InitiativeValue"].Compute("SUM(Amount)",
                                                "ReferenceID = " + intInitiativeFinancialID.ToString());

                if (intInitiativeID > 0)
                    tdDepreciationCell.InnerText = (objDepreciation != DBNull.Value) ? ((Decimal)objDepreciation).ToString("N2") : "0.00";
                else
                    tdDepreciationCell.InnerText = "";

                if (e.Item.ItemType == ListItemType.Item)
                    tdDepreciationCell.Attributes.Add("Class", "depreciationcell");
                else
                    tdDepreciationCell.Attributes.Add("Class", "altdepreciationcell");

                tdDepreciationCell.Attributes.Add("Width", DefaultCellWidth);
                tdDepreciationCell.Attributes.Add("Align", "center");
                tdDepreciationCell.Attributes.Add("style", style);

                trItemRow.Cells.Add(tdDepreciationCell);

                tdDepreciationCell = new HtmlTableCell();
                tdDepreciationCell.Attributes.Add("Class", "emptynopadding");
                trItemRow.Cells.Add(tdDepreciationCell);

                // }
            }
        }


        protected void repeaters_ItemCommand(object source, RepeaterCommandEventArgs e)
        {
            switch (e.CommandName)
            {
                case "Delete":

                    if (e.CommandArgument != null && e.CommandArgument != String.Empty)
                    {
                        int intInitiativeFinancialID = Int32.Parse(e.CommandArgument.ToString());
                        SectionC_DB.DeleteInitiativeFinancial(nInitiativeID, intInitiativeFinancialID);

                        DataRow[] drDeletedRecords;

                        drDeletedRecords = m_dsFinancialRecords.Tables["FinancialRecords"].Select(
                                                                "InitiativeID=" + nInitiativeID.ToString() +
                                                                " AND InitiativeFinancialID=" + intInitiativeFinancialID.ToString());

                        foreach (DataRow drRecord in drDeletedRecords)
                        {
                            m_dsFinancialRecords.Tables["FinancialRecords"].Rows.Remove(drRecord);
                        }

                        drDeletedRecords = m_dsInitiativeValues.Tables["InitiativeValue"].Select
                                                                ("InitiativeID=" + nInitiativeID.ToString() +
                                                                " AND ReferenceID=" + intInitiativeFinancialID.ToString());

                        foreach (DataRow drRecord in drDeletedRecords)
                        {
                            m_dsInitiativeValues.Tables["InitiativeValue"].Rows.Remove(drRecord);
                        }
                    }

                    BindRepeaters();

                    //rev 1.2.1 CA
                    Response.Redirect("~/default.aspx?section=2&InitiativeID=" + nInitiativeID.ToString());
                    //end rev 1.2.1

                    break;


                case "Clear":

                    if (e.CommandArgument != null && e.CommandArgument != String.Empty)
                    {
                        int intInitiativeFinancialID = Int32.Parse(e.CommandArgument.ToString());

                        SectionC_DB.ClearInitiativeFinancial(nInitiativeID, intInitiativeFinancialID);
                        SectionC_DB.ClearInitiativeFinancialValues(nInitiativeID, intInitiativeFinancialID);

                        DataRow[] drClearedRecords;

                        drClearedRecords = m_dsFinancialRecords.Tables["FinancialRecords"].Select(
                                                                "InitiativeID=" + nInitiativeID.ToString() +
                                                                " AND InitiativeFinancialID=" + intInitiativeFinancialID.ToString());

                        foreach (DataRow drRecord in drClearedRecords)
                        {
                            drRecord["StartDate"] = DBNull.Value;
                        }

                        drClearedRecords = m_dsInitiativeValues.Tables["InitiativeValue"].Select
                                                                ("InitiativeID=" + nInitiativeID.ToString() +
                                                                " AND ReferenceID=" + intInitiativeFinancialID.ToString());

                        foreach (DataRow drRecord in drClearedRecords)
                        {
                            drRecord["Amount"] = 0.0d;
                        }
                    }

                    BindRepeaters();

                    break;
            }
        }
    }
}
