    public partial class SectionC : System.Web.UI.UserControl
    {
        protected int nInitiativeID;

        private DataSet m_dsPeriod;
        private DataSet m_dsInitiativeValues;
        private DataSet m_dsFinancialRecords;

        private const string DefaultCellWidth = "55px";
        private const string Pre2006CellWidth = "75px";


        protected void Page_Load(object sender, EventArgs e)
        {
            try
            {
                nInitiativeID = Int32.Parse(Request.QueryString["InitiativeID"]);
            }
            catch (Exception)
            {
                nInitiativeID = -1;
            }

            // rev 1.2.1 CA
            m_dsFinancialRecords = SectionC_DB.GetAllFinancialRecords(nInitiativeID);

            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=6").ToString() != "0")
            {
                lblCapitalHardware.Visible = true;
            }
            else
            {
                lblCapitalHardware.Visible = false;
            }

            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=7").ToString() != "0")
            {
                lblBuildingPremises.Visible = true;
            }
            else
            {
                lblBuildingPremises.Visible = false;
            }

            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=8").ToString() != "0")
            {
                lblCapitalSoftware.Visible = true;
            }
            else
            {
                lblCapitalSoftware.Visible = false;
            }

            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=15").ToString() != "0")
            {
                lblMarketData.Visible = true;
            }
            else
            {
                lblMarketData.Visible = false;
            }

            // end rev 1.2.1

            btnAddBenefit.Attributes.Add("onclick", "javascript:popupWindowAddFinancial(" + nInitiativeID.ToString() + ", 1, 0)");
            btnAddSpend.Attributes.Add("onclick", "javascript:popupWindowAddFinancial(" + nInitiativeID.ToString() + ", 2, 0)");
            btnAddRTBExisting.Attributes.Add("onclick", "javascript:popupWindowAddFinancial(" + nInitiativeID.ToString() + ", 9, 0)");
            btnAddCapex.Attributes.Add("onclick", "javascript:popupWindowAddFinancialCapex(" + nInitiativeID.ToString() + ", 6, 0)");

            //m_dsPeriod = Global_DB.GetPeriods(nInitiativeID);
            m_dsPeriod = Global_DB.GetPeriodsForDisplay(nInitiativeID);
            //m_dsInitiativeValues = SectionC_DB.GetInitiativeValues(nInitiativeID);
            m_dsInitiativeValues = SectionC_DB.GetInitiativeValuesForDisplay(nInitiativeID);
            m_dsFinancialRecords = SectionC_DB.GetAllFinancialRecords(nInitiativeID);

            if (!Page.IsPostBack)
            {
                LoadInitiative();
            }

            BindRepeaters();
        }


        protected void BindRepeaters()
        {

            m_dsFinancialRecords = SectionC_DB.GetAllFinancialRecords(nInitiativeID);
            m_dsInitiativeValues = SectionC_DB.GetInitiativeValuesForDisplay(nInitiativeID);

            DataView dvBenefits = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvBenefits.RowFilter = "CategoryID=1";

            rptBenefits.DataSource = dvBenefits;
            rptBenefits.DataBind();

            DataView dvSpendGTOOneTimeCosts = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendGTOOneTimeCosts.RowFilter = "CategoryID=2";

            rptSpendGTOOneTimeCosts.DataSource = dvSpendGTOOneTimeCosts;
            rptSpendGTOOneTimeCosts.DataBind();

            DataView dvSpendBusinessOneTimeCosts = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendBusinessOneTimeCosts.RowFilter = "CategoryID=3";

            rptSpendBusinessOneTimeCosts.DataSource = dvSpendBusinessOneTimeCosts;
            rptSpendBusinessOneTimeCosts.DataBind();

            DataView dvSpendGTORunningCosts = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendGTORunningCosts.RowFilter = "CategoryID=4";

            rptSpendGTORunningCosts.DataSource = dvSpendGTORunningCosts;
            rptSpendGTORunningCosts.DataBind();

            DataView dvSpendBusinessRunningCosts = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendBusinessRunningCosts.RowFilter = "CategoryID=5";

            rptSpendBusinessRunningCosts.DataSource = dvSpendBusinessRunningCosts;
            rptSpendBusinessRunningCosts.DataBind();


            DataView dvRTBExisting = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvRTBExisting.RowFilter = "";

            // Rev 1.7.2 GMcF
            DataView dvSpendRTBX_GTO = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendRTBX_GTO.RowFilter = "CategoryID in ( 9, 16 )";

            rptSpendRTBX_GTO.DataSource = dvSpendRTBX_GTO;
            rptSpendRTBX_GTO.DataBind();

            DataView dvSpendRTBX_BusinessDirect = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendRTBX_BusinessDirect.RowFilter = "CategoryID = 17";

            rptSpendRTBX_BusinessDirect.DataSource = dvSpendRTBX_BusinessDirect;
            rptSpendRTBX_BusinessDirect.DataBind();

            DataView dvSpendRTBX_Total = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendRTBX_Total.RowFilter = "CategoryID in ( 9, 16, 17 )";

            rptSpendRTBX_Total.DataSource = dvSpendRTBX_Total;
            rptSpendRTBX_Total.DataBind();
            // End Rev 1.7.2

            DataView dvGTOAnalysis = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvGTOAnalysis.RowFilter = "CategoryID=2 OR CategoryID=4";

            rptGTOAnalysis.DataSource = dvGTOAnalysis;
            rptGTOAnalysis.DataBind();


            DataView dvCAPEXCapitalHardware = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvCAPEXCapitalHardware.RowFilter = "CategoryID=6";

            rptCAPEXCapitalHardware.DataSource = dvCAPEXCapitalHardware;
            rptCAPEXCapitalHardware.DataBind();

            //rev 1.2.1 CA
            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=6").ToString() != "0")
            {
                lblCapitalHardware.Visible = true;
            }
            //end rev 1.2.1

            DataView dvCAPEXBuildingPremises = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvCAPEXBuildingPremises.RowFilter = "CategoryID=7";

            rptCAPEXBuildingPremises.DataSource = dvCAPEXBuildingPremises;
            rptCAPEXBuildingPremises.DataBind();

            //rev 1.2.1 CA
            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=7").ToString() != "0")
            {
                lblBuildingPremises.Visible = true;
            }
            //end rev 1.2.1

            DataView dvCAPEXCapitalSoftware = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvCAPEXCapitalSoftware.RowFilter = "CategoryID=8";

            rptCAPEXCapitalSoftware.DataSource = dvCAPEXCapitalSoftware;
            rptCAPEXCapitalSoftware.DataBind();

            //rev 1.2.1 CA
            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=8").ToString() != "0")
            {
                lblCapitalSoftware.Visible = true;
            }
            //end rev 1.2.1

            //rev 1.2.1 CA
            DataView dvCAPEXMarketData = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvCAPEXMarketData.RowFilter = "CategoryID=15";

            rptCAPEXMarketData.DataSource = dvCAPEXMarketData;
            rptCAPEXMarketData.DataBind();

            if (m_dsFinancialRecords.Tables["FinancialRecords"].Compute("COUNT(InitiativeFinancialID)", "CategoryID=15").ToString() != "0")
            {
                lblMarketData.Visible = true;
            }
            //end rev 1.2.1

            // Ionut
            DataView dvSpendGTOOneTimeCostsDepreciation = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendGTOOneTimeCostsDepreciation.RowFilter = "CategoryID=11";

            rptSpendGTOOneTimeCostsDepreciation.DataSource = dvSpendGTOOneTimeCostsDepreciation;
            rptSpendGTOOneTimeCostsDepreciation.DataBind();

            DataView dvSpendBusinessOneTimeCostsDepreciation = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendBusinessOneTimeCostsDepreciation.RowFilter = "CategoryID=12";

            rptSpendBusinessOneTimeCostsDepreciation.DataSource = dvSpendBusinessOneTimeCostsDepreciation;
            rptSpendBusinessOneTimeCostsDepreciation.DataBind();

            DataView dvSpendGTORunningCostsDepreciation = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendGTORunningCostsDepreciation.RowFilter = "CategoryID=13";

            rptSpendGTORunningCostsDepreciation.DataSource = dvSpendGTORunningCostsDepreciation;
            rptSpendGTORunningCostsDepreciation.DataBind();

            DataView dvSpendBusinessRunningCostsDepreciation = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvSpendBusinessRunningCostsDepreciation.RowFilter = "CategoryID=14";

            rptSpendBusinessRunningCostsDepreciation.DataSource = dvSpendBusinessRunningCostsDepreciation;
            rptSpendBusinessRunningCostsDepreciation.DataBind();



            DataView dvPayBack = new DataView(m_dsFinancialRecords.Tables["FinancialRecords"]);
            dvPayBack.RowFilter = "";

            rptPayBack.DataSource = dvPayBack;
            rptPayBack.DataBind();
        }


        protected void LoadInitiative()
        {

            DataRow drInitiative = SectionC_DB.GetInitiativeDetails(nInitiativeID);

            if (drInitiative != null)
            {
                ddlAdditionalConsumption.SelectedValue = drInitiative["RTBAdditionalConsumptionID"].ToString();
            }
        }


        public int UpdateInitiative()
        {
            int intReturnValue = -1;

            if (nInitiativeID > 0)
            {
                intReturnValue = SectionC_DB.UpdateInitiative(
                                    nInitiativeID,
                                    ddlAdditionalConsumption.SelectedItem.Text,
                                    Convert.ToInt32(ddlAdditionalConsumption.SelectedValue));
            }

            return intReturnValue;
        }


        protected void rptBenefits_ItemDataBound(object sender, RepeaterItemEventArgs e)
        {
            switch (e.Item.ItemType)
            {
                case ListItemType.Header:
                    repeaters_DoDefaultHeaderBind(sender, e);
                    break;

                case ListItemType.Item:
                case ListItemType.AlternatingItem:
                    repeaters_DoDefaultItemBind(sender, e);
                    break;

                case ListItemType.Footer:
                    repeaters_DoDefaultFooterBind(sender, e, "(CategoryID=1)", "trTotal", "", "totalcell");
                    break;
            }
        }


