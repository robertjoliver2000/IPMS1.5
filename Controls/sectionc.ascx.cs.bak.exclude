        protected void rptCAPEXCapitalHardware_ItemDataBound(object sender, RepeaterItemEventArgs e)
        {
            switch (e.Item.ItemType)
            {
                case ListItemType.Header:
                    repeaters_DoDefaultHeaderBind(sender, e);
                    break;

                case ListItemType.Item:
                case ListItemType.AlternatingItem:
                    repeaters_DoDefaultItemBind(sender, e);
                    break;

                //case ListItemType.Footer:
                //    break;

                case ListItemType.Footer:

                    //rev 1.2.1 CA
                    if (lblMarketData.Visible || lblBuildingPremises.Visible || lblCapitalHardware.Visible || lblCapitalSoftware.Visible)
                    {
                        repeaters_DoDefaultFooterBind(sender, e, "((CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND Type='GTO Capex')", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal11", "background-color:#F0FFF2;", "totalcell");
                        repeaters_DoDefaultFooterBind(sender, e, "((CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND Type='Business Capex')", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal21", "background-color:#F0FFF2;", "totalcell");
                        repeaters_DoDefaultFooterBind(sender, e, "(CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15)", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal31", "background-color:#F0FFF2;", "totalcell");

                        repeaters_DoDefaultFooterBind(sender, e, "(CategoryID=11 OR CategoryID=12 OR CategoryID=13 OR CategoryID=14)",
                                                        "trDepreciation1", "background-color:#F0FFF2;", "totalcell");

                    }
                    break;
                    // end rev 1.2.1
            }
            //rev 1.2.1 CA
            if ((((lblMarketData.Visible == true) || (lblBuildingPremises.Visible == true) || (lblCapitalSoftware.Visible == true)) == true) || (lblCapitalHardware.Visible == false))
            //if (((lblMarketData.Visible == false) && (lblBuildingPremises.Visible == false) && (lblCapitalSoftware.Visible == false)) == true)
            {
                Label lblTotalGTOCapex1 = (Label)e.Item.FindControl("lblTotalGTOCapex1");
                if (lblTotalGTOCapex1 != null)
                {
                    lblTotalGTOCapex1.Visible = false;
                }

                Label lblTotalBusinessCapex1 = (Label)e.Item.FindControl("lblTotalBusinessCapex1");
                if (lblTotalBusinessCapex1 != null)
                {
                    lblTotalBusinessCapex1.Visible = false;
                }

                Label lblTotalCapex1 = (Label)e.Item.FindControl("lblTotalCapex1");
                if (lblTotalCapex1 != null)
                {
                    lblTotalCapex1.Visible = false;
                }

                Label lblTotalDepreciation1 = (Label)e.Item.FindControl("lblTotalDepreciation1");
                if (lblTotalDepreciation1 != null)
                {
                    lblTotalDepreciation1.Visible = false;
                }


                HtmlTableRow trSubTotal11 = (HtmlTableRow)e.Item.FindControl("trSubTotal11");
                if (trSubTotal11 != null)
                {
                    trSubTotal11.Visible = false;
                }

                HtmlTableRow trSubTotal21 = (HtmlTableRow)e.Item.FindControl("trSubTotal21");
                if (trSubTotal21 != null)
                {
                    trSubTotal21.Visible = false;
                }

                HtmlTableRow trSubTotal31 = (HtmlTableRow)e.Item.FindControl("trSubTotal31");
                if (trSubTotal31 != null)
                {
                    trSubTotal31.Visible = false;
                }

                HtmlTableRow trDepreciation1 = (HtmlTableRow)e.Item.FindControl("trDepreciation1");
                if (trDepreciation1 != null)
                {
                    trDepreciation1.Visible = false;
                }

                HtmlTableRow trblank11 = (HtmlTableRow)e.Item.FindControl("trblank11");
                if (trblank11 != null)
                {
                    trblank11.Visible = false;
                }

                HtmlTableRow trblank21 = (HtmlTableRow)e.Item.FindControl("trblank21");
                if (trblank21 != null)
                {
                    trblank21.Visible = false;
                }

                HtmlTableRow trblank31 = (HtmlTableRow)e.Item.FindControl("trblank31");
                if (trblank31 != null)
                {
                    trblank31.Visible = false;
                }

                HtmlTableRow trblank41 = (HtmlTableRow)e.Item.FindControl("trblank41");
                if (trblank41 != null)
                {
                    trblank41.Visible = false;
                }

                HtmlTableRow trblank51 = (HtmlTableRow)e.Item.FindControl("trblank51");
                if (trblank51 != null)
                {
                    trblank51.Visible = false;
                }
            }
            // end rev 1.2.1

        }


        protected void rptCAPEXBuildingPremises_ItemDataBound(object sender, RepeaterItemEventArgs e)
        {
            switch (e.Item.ItemType)
            {
                case ListItemType.Item:
                case ListItemType.AlternatingItem:
                    repeaters_DoDefaultItemBind(sender, e);
                    break;

                case ListItemType.Footer:

                    //rev 1.2.1 CA
                    if (lblMarketData.Visible || lblBuildingPremises.Visible || lblCapitalHardware.Visible || lblCapitalSoftware.Visible)
                    {
                        repeaters_DoDefaultFooterBind(sender, e, "((CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND Type='GTO Capex')", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal12", "background-color:#F0FFF2;", "totalcell");
                        repeaters_DoDefaultFooterBind(sender, e, "((CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15) AND Type='Business Capex')", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal22", "background-color:#F0FFF2;", "totalcell");
                        repeaters_DoDefaultFooterBind(sender, e, "(CategoryID=6 OR CategoryID=7 OR CategoryID=8 OR CategoryID=15)", //rev 1.2.1 added Category 15 CA
                                                        "trSubTotal32", "background-color:#F0FFF2;", "totalcell");

                        repeaters_DoDefaultFooterBind(sender, e, "(CategoryID=11 OR CategoryID=12 OR CategoryID=13 OR CategoryID=14)",
                                                        "trDepreciation2", "background-color:#F0FFF2;", "totalcell");

                    }
                    break;
                    // end rev 1.2.1
            }
            //rev 1.2.1 CA
            if ((((lblMarketData.Visible == true) || (lblCapitalSoftware.Visible == true)) == true) || (lblBuildingPremises.Visible == false))
            //if (((lblMarketData.Visible == false) && (lblCapitalHardware.Visible == false) && (lblCapitalSoftware.Visible == false)) == true)
            {
                Label lblTotalGTOCapex2 = (Label)e.Item.FindControl("lblTotalGTOCapex2");
                if (lblTotalGTOCapex2 != null)
                {
                    lblTotalGTOCapex2.Visible = false;
                }

                Label lblTotalBusinessCapex2 = (Label)e.Item.FindControl("lblTotalBusinessCapex2");
                if (lblTotalBusinessCapex2 != null)
                {
                    lblTotalBusinessCapex2.Visible = false;
                }

                Label lblTotalCapex2 = (Label)e.Item.FindControl("lblTotalCapex2");
                if (lblTotalCapex2 != null)
                {
                    lblTotalCapex2.Visible = false;
                }

                Label lblTotalDepreciation2 = (Label)e.Item.FindControl("lblTotalDepreciation2");
                if (lblTotalDepreciation2 != null)
                {
                    lblTotalDepreciation2.Visible = false;
                }


